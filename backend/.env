# =========================================================================
# STARTUP OPPORTUNITY AGGREGATOR - DATABASE & SCHEDULER ENVIRONMENT SETTINGS
# =========================================================================

# -------------------------------------------------------------------------
# OPTION 1: SQLite (Default - Super Simple & Zero Setup)
# -------------------------------------------------------------------------
DATABASE_URL=sqlite:///./startup_opportunities.db

# -------------------------------------------------------------------------
# OPTION 2: PostgreSQL (Recommended for Professional and Hackathon High Scores)
# -------------------------------------------------------------------------
# Swap to this syntax if you are using PostgreSQL (e.g. pgAdmin, AWS RDS, Supabase, Docker Postgres)
# FORMAT: postgresql://[username]:[password]@[host]:[port]/[database_name]
# Example (Local Docker/pgAdmin):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/startup_opportunities
# Example (Cloud Supabase/Neon PostgreSQL):
# DATABASE_URL=postgresql://neondb_owner:npg_xyz@ep-plain-field-1234.us-east-2.aws.neon.tech/startup_opportunities?sslmode=require

# -------------------------------------------------------------------------
# OTHER CONFIGURATIONS
# -------------------------------------------------------------------------
# The origin of your React frontend app to allow cross-origin requests (CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Scraper Interval in minutes (set to 0 to disable automated scheduler)
SCRAPE_INTERVAL_MINUTES=30

# Request timeouts and retries per public source parser
SCRAPER_TIMEOUT_SECONDS=3
SCRAPER_MAX_RETRIES=1

# Set to true to populate the DB with 105+ high-quality real-world pre-seeded startup opportunities
SEED_ON_STARTUP=true
